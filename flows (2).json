    {
        "id": "01187cab72413557",
        "type": "function",
        "z": "395a6f858483d24d",
        "name": "separaçao",
        "func": "// 1. Busca os valores da gaveta GLOBAL (o caderno compartilhado)\nlet totalPecas = global.get(\"totalPecas\") || 0;\nlet status = flow.get(\"status_maquina\") || \"RUNNING\";\n\nlet ciclo = 0;\nlet acerto = 0;\n\n// 2. LÓGICA DE DECISÃO\nif (status === \"RUNNING\") {\n    // SÓ INCREMENTA SE ESTIVER RODANDO\n    totalPecas += 1; \n    global.set(\"totalPecas\", totalPecas); // Salva de volta no caderno global\n\n    // Gera os dados simulados de produção\n    ciclo = (Math.random() * (4.5 - 3.5) + 3.5).toFixed(1);\n    acerto = (98 + Math.random()).toFixed(1);\n} else {\n    // SE ESTIVER EM 'STOPPED', O CICLO VAI PARA 0 E A CONTAGEM TRAVA\n    ciclo = 0;\n    acerto = 0;\n}\n\n// 3. Prepara o pacote para o Next.js\nmsg.payload = {\n    pecas: totalPecas,\n    ciclo: parseFloat(ciclo),\n    acerto: parseFloat(acerto),\n    status: status\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
